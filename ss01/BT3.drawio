        <mxCell id="t2LG4mHw0YLMwWvMlcQX-38" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;" value="&lt;li&gt;&lt;p data-path-to-node=&quot;4,0,0&quot;&gt;&lt;b data-path-to-node=&quot;4,0,0&quot; data-index-in-node=&quot;0&quot;&gt;Thực thể (Hình chữ nhật):&lt;/b&gt;&lt;/p&gt;&lt;ul data-path-to-node=&quot;4,0,1&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,0,1,0,0&quot;&gt;&lt;b data-path-to-node=&quot;4,0,1,0,0&quot; data-index-in-node=&quot;0&quot;&gt;STUDENTS:&lt;/b&gt; Lưu thông tin người mượn.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,0,1,1,0&quot;&gt;&lt;b data-path-to-node=&quot;4,0,1,1,0&quot; data-index-in-node=&quot;0&quot;&gt;LOAN_CARDS:&lt;/b&gt; Lưu thông tin chung của một lần mượn (số phiếu, ngày mượn).&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,0,1,2,0&quot;&gt;&lt;b data-path-to-node=&quot;4,0,1,2,0&quot; data-index-in-node=&quot;0&quot;&gt;BOOKS:&lt;/b&gt; Lưu thông tin về các cuốn sách trong kho.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,1,0&quot;&gt;&lt;b data-path-to-node=&quot;4,1,0&quot; data-index-in-node=&quot;0&quot;&gt;Thuộc tính (Hình Oval):&lt;/b&gt;&lt;/p&gt;&lt;ul data-path-to-node=&quot;4,1,1&quot;&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,1,1,0,0&quot;&gt;&lt;b data-path-to-node=&quot;4,1,1,0,0&quot; data-index-in-node=&quot;0&quot;&gt;STUDENTS:&lt;/b&gt; &lt;code data-path-to-node=&quot;4,1,1,0,0&quot; data-index-in-node=&quot;10&quot;&gt;StudentID&lt;/code&gt; (PK), &lt;code data-path-to-node=&quot;4,1,1,0,0&quot; data-index-in-node=&quot;26&quot;&gt;Fullname&lt;/code&gt;, &lt;code data-path-to-node=&quot;4,1,1,0,0&quot; data-index-in-node=&quot;36&quot;&gt;Class&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,1,1,1,0&quot;&gt;&lt;b data-path-to-node=&quot;4,1,1,1,0&quot; data-index-in-node=&quot;0&quot;&gt;LOAN_CARDS:&lt;/b&gt; &lt;code data-path-to-node=&quot;4,1,1,1,0&quot; data-index-in-node=&quot;12&quot;&gt;CardID&lt;/code&gt; (PK), &lt;code data-path-to-node=&quot;4,1,1,1,0&quot; data-index-in-node=&quot;25&quot;&gt;LoanDate&lt;/code&gt;, &lt;code data-path-to-node=&quot;4,1,1,1,0&quot; data-index-in-node=&quot;35&quot;&gt;DueDate&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p data-path-to-node=&quot;4,1,1,2,0&quot;&gt;&lt;b data-path-to-node=&quot;4,1,1,2,0&quot; data-index-in-node=&quot;0&quot;&gt;BOOKS:&lt;/b&gt; &lt;code data-path-to-node=&quot;4,1,1,2,0&quot; data-index-in-node=&quot;7&quot;&gt;BookID&lt;/code&gt; (PK), &lt;code data-path-to-node=&quot;4,1,1,2,0&quot; data-index-in-node=&quot;20&quot;&gt;Title&lt;/code&gt;, &lt;code data-path-to-node=&quot;4,1,1,2,0&quot; data-index-in-node=&quot;27&quot;&gt;Author&lt;/code&gt;.&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;" vertex="1">
